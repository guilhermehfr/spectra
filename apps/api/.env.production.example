# Django settings (OBRIGATÓRIO em produção)
SECRET_KEY=generate-a-strong-secret-key-here
DEBUG=False

# Allowed hosts (OBRIGATÓRIO em produção - não use '*')
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CORS origins (OBRIGATÓRIO em produção)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Database (PostgreSQL para produção)
# Use DATABASE_URL (recomendado) - formato: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://your_db_user:your_db_password@your-db-host.onrender.com:5432/your_db_name

# Ambiente
DJANGO_ENV=production