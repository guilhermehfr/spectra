# Django settings
SECRET_KEY=generate-a-strong-secret-key-here
DEBUG=False

# Allowed hosts (replace with your production domain)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# CORS origins (replace with your production frontend domain)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Database (PostgreSQL for production)
# Use DATABASE_URL (recommended) - format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://your_db_user:your_db_password@your-db-host.onrender.com:5432/your_db_name