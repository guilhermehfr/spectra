# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Allowed hosts for local development
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins for local development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed secret for dev seeding
SEED_SECRET=your-seed-secret-here

# >> DEMO PROD << DATABASES URLS
#
# CENTRAL_DATABASE_URL=
# ALPHA_DB_URL=
# BETA_DB_URL=

# >> DEV LOCAL << DATABASES URLS
CENTRAL_DATABASE_URL=sqlite:///db.sqlite3
ALPHA_DB_URL=sqlite:///alpha.sqlite3
BETA_DB_URL=sqlite:///beta.sqlite3