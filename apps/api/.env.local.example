# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seed secret for dev seeding
SEED_SECRET=your-seed-secret-here

# Database URLs
# ALPHA and BETA are used to represent different clinics DBs.
CENTRAL_DATABASE_URL=sqlite:///db.sqlite3
ALPHA_DB_URL=sqlite:///alpha.sqlite3
BETA_DB_URL=sqlite:///beta.sqlite3