# Local Django API URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Set the Node environment to development
NODE_ENV=development

# Define if the app uses mock data or real API calls
NEXT_PUBLIC_DISABLE_MSW=false

# Mock stored user ID
#
# Options: 1 (admin), 2 (therapist), 3 (therapist), 4 (family)
#
# Any of the options value attributed to this variable will BYPASS authentication
# Set to an empty value to enable authentication flow
NEXT_PUBLIC_MOCK_USER_ID=1
