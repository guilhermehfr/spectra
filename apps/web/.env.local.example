# API URL for local development environment
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Set the Node environment to development
NODE_ENV=development

# Control Mock vs Real API Mode
# ───────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_DISABLE_MSW controls whether the app uses mock data or real API calls.
# This setting affects the entire data layer (auth, clinic, family APIs).
#
# false (DEFAULT in development):
#   - Uses in-memory mock state (no HTTP requests made)
#   - All API data comes from src/mocks/state.ts
#   - Auth functions work in-memory without fetch
#   - Eliminates "Failed to fetch" errors
#   - Recommended for development without a backend server
#
# true (PRODUCTION or real backend):
#   - Uses real HTTP requests via the 'http' client
#   - All API data comes from the backend at NEXT_PUBLIC_API_URL
#   - Requires the Django backend to be running
#   - MSW (Mock Service Worker) is not started
#
# Note: The mock/real implementations are determined at lazy-load time.
#       Change this value and restart the dev server for changes to take effect.
#
NEXT_PUBLIC_DISABLE_MSW=false

# Mock stored user ID for development environment
# Only used when NEXT_PUBLIC_DISABLE_MSW=false
# Options: 1 (admin), 2 (therapist), 3 (therapist), 4 (family)
# Default: 1 (admin user)
NEXT_PUBLIC_MOCK_USER_ID=1
